# Kabacal cloud — copy to supabase/.env for local tooling. NEVER commit .env.
# docs/SAAS.md "Secrets policy" is the rule book.

# Client-side config (public BY DESIGN — RLS is the security boundary, not this key).
# At Phase 1 these two also get inlined into index.html's cloud config / kab_cloud.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=eyJ...paste-anon-public-key...

# ---- server-side ONLY — set as Supabase Edge Function secrets, never here, never in index.html
# SUPABASE_SERVICE_ROLE_KEY=   # full-DB bypass key: dashboard/Edge only
# STRIPE_SECRET_KEY=           # Phase 4
# STRIPE_WEBHOOK_SECRET=       # Phase 4
